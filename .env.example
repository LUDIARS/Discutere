# Discutere Service Configuration
BACKEND_PORT=3100
DATABASE_PATH=data/discutere.db

# Cernere Integration (3-point auth)
CERNERE_WS_URL=ws://localhost:8080/ws/service
CERNERE_SERVICE_CODE=discutere
CERNERE_SERVICE_SECRET=
SERVICE_JWT_SECRET=discutere-dev-secret

# Frontend
FRONTEND_URL=http://localhost:5174

# Channel Mode "task" — Haiku でタスク判定 (未設定時はルールベースに fallback)
ANTHROPIC_API_KEY=
HAIKU_MODEL=claude-haiku-4-5-20251001

# Channel Mode "discussion" — 要約を GitHub Discussion に保存 (未設定時はローカルのみ)
GITHUB_TOKEN=
