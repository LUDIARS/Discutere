# Discutere Service Configuration
# 通常は Infisical + env-cli 経由で生成します (npm run env:env)。
# これは手動で管理する場合のサンプルです。

# ─── Ports ─────────────────────────────────────────────
FRONTEND_PORT=5174
BACKEND_PORT=3100

# ─── Database ──────────────────────────────────────────
DATABASE_PATH=data/discutere.db

# ─── Vite ──────────────────────────────────────────────
VITE_ALLOWED_HOSTS=

# ─── Application ───────────────────────────────────────
FRONTEND_URL=http://localhost:5174
CERNERE_URL=http://localhost:8080

# ─── JWT (Discutere 独自の service_token 用) ───────────
JWT_SECRET=discutere-dev-secret-change-in-production

# ─── Cernere プロジェクト認証 ──────────────────────────
CERNERE_PROJECT_CLIENT_ID=
CERNERE_PROJECT_CLIENT_SECRET=

# ─── 任意 (機能別) ─────────────────────────────────────
# ANTHROPIC_API_KEY=       # task モードの Haiku 判定
# HAIKU_MODEL=claude-haiku-4-5-20251001
# GITHUB_TOKEN=            # discussion モードの GitHub Discussion 書き込み
